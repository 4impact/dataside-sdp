<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProfile name="!local">
        <!-- JSON structured logging for production / container environments -->
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdcKeyName>messageId</includeMdcKeyName>
                <includeMdcKeyName>operation</includeMdcKeyName>
                <includeMdcKeyName>sdpRequestId</includeMdcKeyName>
                <fieldNames>
                    <timestamp>@timestamp</timestamp>
                    <version>[ignore]</version>
                    <levelValue>[ignore]</levelValue>
                </fieldNames>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
        </root>
    </springProfile>

    <springProfile name="local">
        <!-- Human-readable logging for local development -->
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level [msgId=%X{messageId}] [op=%X{operation}] %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

        <logger name="com.fourimpact.sdpsinkconnector" level="DEBUG"/>
    </springProfile>
</configuration>
