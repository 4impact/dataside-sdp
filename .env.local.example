# Copy this file to .env.local and fill in your actual values.
# These are loaded manually (see run-local.sh) or set in your IDE run configuration.

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_INPUT_TOPIC=sdp-requests
KAFKA_DLQ_TOPIC=sdp-requests-dlq
KAFKA_GROUP_ID=sdp-sink-connector

# SDP connection
SDP_BASE_URL=https://your-sdp-instance.com
SDP_PORTAL=your-portal-name

# Auth — choose one
SDP_AUTH_TYPE=API_KEY
SDP_API_KEY=your-api-key-here

# OAuth2 (only needed when SDP_AUTH_TYPE=OAUTH2)
#SDP_OAUTH_TOKEN_URL=
#SDP_OAUTH_CLIENT_ID=
#SDP_OAUTH_CLIENT_SECRET=
